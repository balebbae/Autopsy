# Backend service
DATABASE_URL=postgresql+asyncpg://aag:aag@localhost:5432/aag
AAG_HOST=0.0.0.0
AAG_PORT=4000
AAG_LOG_LEVEL=info

# Plugin → service
AAG_URL=http://localhost:4000
AAG_TOKEN=devtoken

# Embedding provider: "stub" (deterministic hash, byte-identical-only retrieval),
# "local" (sentence-transformers — requires `cd service && uv sync --extra ml`),
# or "openai" (hosted, requires OPENAI_API_KEY below).
# `stub` keeps the default boot working without heavy ML deps; flip to `local`
# or `openai` for real semantic similarity (see `make demo-prep`).
EMBED_PROVIDER=stub
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional API keys (only needed if EMBED_PROVIDER=openai or for LLM-assisted analyzer)
OPENAI_API_KEY=

# LLM classification: "none" (rule-based only) or "gemma" (Google AI Studio)
LLM_PROVIDER=none
GEMMA_MODEL=gemma-3-12b-it
GEMINI_API_KEY=

# Dashboard
NEXT_PUBLIC_AAG_URL=http://localhost:4000
