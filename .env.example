# Backend service
DATABASE_URL=postgresql+asyncpg://aag:aag@localhost:5432/aag
AAG_HOST=0.0.0.0
AAG_PORT=4000
AAG_LOG_LEVEL=info

# Plugin → service
AAG_URL=http://localhost:4000
AAG_TOKEN=devtoken

# Embedding provider. Default is "gemini" — free via Gemini API (768-d,
# Google ``gemini-embedding-001`` MRL-truncated to 768d), uses the same
# GEMINI_API_KEY as the Gemma classifier. Other options:
#   "stub"   deterministic hash, byte-identical-only retrieval, also 768d
#            so it shares the schema with gemini (no embed-reset needed
#            when switching between gemini and stub for offline dev).
#   "local"  sentence-transformers — requires `cd service && uv sync --extra ml`,
#            384d, requires `make embed-reset` after switching to it.
#   "openai" hosted (text-embedding-3-small), 1536d, requires OPENAI_API_KEY
#            and `make embed-reset` after switching to it.
EMBED_PROVIDER=gemini
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional API keys (only needed if EMBED_PROVIDER=openai or for LLM-assisted analyzer)
OPENAI_API_KEY=

# LLM classification: "none" (rule-based only) or "gemma" (Google AI Studio)
# GEMINI_API_KEY is also used by EMBED_PROVIDER=gemini — one key covers both.
LLM_PROVIDER=none
GEMMA_MODEL=gemma-3-12b-it
GEMINI_API_KEY=

# Stale-run sweeper. Flips abandoned 'active' runs to 'aborted' when the
# plugin couldn't post a final outcome (SIGKILL, laptop crashed, etc).
# Variable names match the pydantic Settings field names (no AAG_ prefix
# is applied — the config uses the field name verbatim).
# STALE_RUN_THRESHOLD_MS=1800000        # 30 min — bump for very long sessions
# STALE_RUN_SWEEP_INTERVAL_MS=60000     # 1 min  — how often to scan
# STALE_RUN_SWEEP_DISABLED=false        # set true to disable entirely

# Dashboard
NEXT_PUBLIC_AAG_URL=http://localhost:4000
