{
  "name": "@aag/opencode-plugin",
  "version": "0.1.0",
  "description": "Agent Autopsy Graph — opencode plugin: records bus events, captures diffs and rejections, and injects preflight warnings into the chat.",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun build src/index.ts --outfile=dist/index.js --target=bun --format=esm"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^0.1.0",
    "typescript": "^5.6.0"
  }
}
